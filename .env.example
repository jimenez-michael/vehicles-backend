# --- Server ---
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# --- Database ---
DATABASE_URL=

# --- Azure AD (auth) ---
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# --- Azure Blob Storage (incident attachments) ---
# Storage account name, e.g. prsciencetrustvehicles
AZURE_STORAGE_ACCOUNT_NAME=
# Storage account key — used to sign SAS tokens. Keep secret.
AZURE_STORAGE_ACCOUNT_KEY=
# Default container for incident attachments
AZURE_STORAGE_INCIDENT_CONTAINER=incident-attachments
# How long upload SAS URLs remain valid (browser PUT window)
AZURE_STORAGE_SAS_UPLOAD_TTL_MINUTES=15
# How long read SAS URLs remain valid (preview/download window)
AZURE_STORAGE_SAS_READ_TTL_MINUTES=60

# --- Anthropic (Claude Vision OCR for license fields) ---
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Model used for license OCR; overridable. Defaults to a current-cap Sonnet.
ANTHROPIC_LICENSE_OCR_MODEL=claude-sonnet-4-6
