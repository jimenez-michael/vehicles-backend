generator client {
  provider      = "prisma-client-js"
  output        = "../node_modules/.prisma/client"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

model Vehicle {
  id             Int            @id @default(autoincrement())
  vehicleNumber  String         @unique @db.VarChar(50)
  make           String         @db.VarChar(100)
  model          String         @db.VarChar(100)
  year           Int
  licensePlate   String         @unique @db.VarChar(50)
  program        String         @db.VarChar(255)
  subProgram     String?        @db.VarChar(255)
  municipality   String?        @db.VarChar(255)
  status         String         @default("AVAILABLE") @db.VarChar(20) // AVAILABLE, IN_USE, OUT_OF_SERVICE
  currentMileage Float          @default(0)
  createdBy      String?        @db.VarChar(255)
  updatedBy      String?        @db.VarChar(255)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  usages         VehicleUsage[]
  reservations   Reservation[]

  @@map("vehicles")
}

model VehicleUsage {
  id        Int      @id @default(autoincrement())
  vehicleId Int
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  status    String   @default("IN_USE") @db.VarChar(20) // IN_USE, COMPLETED

  // Pickup fields
  userId             String   @db.VarChar(255)
  userName           String   @db.VarChar(255)
  userEmail          String   @db.VarChar(255)
  pickupDate         DateTime
  pickupMileage      Float
  gasLevel             String   @default("full") @db.VarChar(10) // full, 3/4, 1/2, 1/4, empty
  interiorCleanliness  String   @default("clean") @db.VarChar(20) // clean, acceptable, dirty
  exteriorCleanliness  String   @default("clean") @db.VarChar(20) // clean, acceptable, dirty
  visibleDamage      Boolean  @default(false)
  visibleDamageDesc  String?  @db.Text
  brokenWindows      Boolean  @default(false)
  brokenWindowsDesc  String?  @db.Text
  lightsWorking      Boolean  @default(true)
  lightsWorkingDesc  String?  @db.Text
  mirrorsOk          Boolean  @default(true)
  mirrorsOkDesc      String?  @db.Text
  tiresOk            Boolean  @default(true)
  tiresOkDesc        String?  @db.Text
  dashboardAlerts    Boolean? // null = N/A
  dashboardAlertDetails String? @db.Text
  pickupObservations String?  @db.Text

  // Return fields
  returnDate         DateTime?
  returnMileage      Float?
  gasFilledUp            Boolean?
  returnInteriorCleanliness String? @db.VarChar(20) // clean, acceptable, dirty
  returnExteriorCleanliness String? @db.VarChar(20) // clean, acceptable, dirty
  incidentOccurred   Boolean?
  incidentDescription String? @db.Text
  policeReportNumber     String?  @db.VarChar(100)
  trustDriverName        String?  @db.VarChar(255)
  thirdPartyName         String?  @db.VarChar(255)
  thirdPartyAddress      String?  @db.VarChar(500)
  thirdPartyPhone        String?  @db.VarChar(50)
  thirdPartyVehicleModel String?  @db.VarChar(255)
  thirdPartyVehicleYear  Int?
  newDamage          Boolean?
  newDamageDesc      String? @db.Text
  interiorConditionOk Boolean?
  interiorConditionDesc String? @db.Text
  properlyParked     Boolean?
  properlyParkedDesc String?  @db.Text
  returnObservations String?  @db.Text

  attachments IncidentAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([vehicleId])
  @@index([userId])
  @@index([status])
  @@index([pickupDate])
  @@index([userId, status])
  @@map("vehicle_usages")
}

// IncidentAttachmentCategory values (enforced at the GraphQL layer; SQL Server
// connector doesn't support Prisma enums):
//   ACCIDENT_FORM | TRUST_VEHICLE_LICENSE | THIRD_PARTY_LICENSE
//   TRUST_VEHICLE_PHOTO | IMPACT_AREA_PHOTO | OTHER
model IncidentAttachment {
  id               Int          @id @default(autoincrement())
  usageId          Int
  vehicleUsage     VehicleUsage @relation(fields: [usageId], references: [id], onDelete: Cascade)
  category         String       @db.VarChar(50)
  blobName         String       @db.VarChar(1024)
  containerName    String       @db.VarChar(255)
  originalFileName String       @db.VarChar(500)
  contentType      String       @db.VarChar(255)
  sizeBytes        Int
  uploadedById     String       @db.VarChar(255)
  uploadedByName   String?      @db.VarChar(255)
  uploadedByEmail  String?      @db.VarChar(255)
  uploadedAt       DateTime     @default(now())

  @@index([usageId])
  @@index([usageId, category])
  @@map("incident_attachments")
}

model AppUserRole {
  id              Int      @id @default(autoincrement())
  assignmentId    String   @unique @db.VarChar(255) // Azure AD assignment ID
  principalId     String   @db.VarChar(255)
  displayName     String   @db.VarChar(255)
  email           String?  @db.VarChar(255)
  appRoleId       String   @db.VarChar(255)
  roleName        String?  @db.VarChar(255)
  createdAt       DateTime @default(now())

  @@index([principalId])
  @@map("app_user_roles")
}

model IncidentNotificationRecipient {
  id        Int      @id @default(autoincrement())
  userId    String   @db.VarChar(255)
  userName  String   @db.VarChar(255)
  userEmail String   @db.VarChar(255)
  createdAt DateTime @default(now())

  @@unique([userId])
  @@map("incident_notification_recipients")
}

model AuditLog {
  id          Int      @id @default(autoincrement())
  action      String   @db.VarChar(100) // e.g. FORCE_CLOSE_USAGE
  actorId     String?  @db.VarChar(255)
  actorName   String?  @db.VarChar(255)
  actorEmail  String?  @db.VarChar(255)
  targetType  String?  @db.VarChar(100) // e.g. VehicleUsage
  targetId    String?  @db.VarChar(255)
  metadata    String?  @db.NVarChar(Max) // JSON blob
  createdAt   DateTime @default(now())

  @@index([action])
  @@index([actorId])
  @@index([targetType, targetId])
  @@index([createdAt])
  @@map("audit_logs")
}

model Reservation {
  id                    Int       @id @default(autoincrement())
  vehicleId             Int
  vehicle               Vehicle   @relation(fields: [vehicleId], references: [id])
  userId                String    @db.VarChar(255)
  userName              String    @db.VarChar(255)
  userEmail             String    @db.VarChar(255)
  startDate             DateTime
  endDate               DateTime
  purpose               String?   @db.Text
  notes                 String?   @db.Text
  status                String    @default("CONFIRMED") @db.VarChar(20) // CONFIRMED, CANCELLED, PENDING_APPROVAL, REJECTED
  calendarEventId       String?   @db.VarChar(255)
  isOvernight           Boolean   @default(false)
  overnightDetails      String?   @db.Text
  approvedByUserId      String?   @db.VarChar(255)
  approvedByName        String?   @db.VarChar(255)
  approvedByEmail       String?   @db.VarChar(255)
  approvalDecisionAt    DateTime?
  approvalDecisionNotes String?   @db.Text
  createdBy             String?   @db.VarChar(255)
  updatedBy             String?   @db.VarChar(255)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([vehicleId])
  @@index([userId])
  @@index([status])
  @@index([startDate])
  @@index([vehicleId, status, startDate, endDate])
  @@map("reservations")
}
